# Copy this file to ".env" and paste your real key. Never commit .env.
# Get a key at https://platform.openai.com/ and pre-fund the account before the hackathon.
OPENAI_API_KEY=sk-...

# Optional: override the model. Defaults to a fast, cheap model good for QA.
MIND_THE_CONTEXT_MODEL=gpt-4o

# --- Local model (optional) ----------------------------------------------
# Pick "Local (Ollama / LM Studio)" in the sidebar instead of using these,
# or set defaults here. No API key needed; nothing leaves your machine.
# Ollama:   http://localhost:11434/v1   (run: ollama run llama3.1)
# LM Studio: http://localhost:1234/v1
LOCAL_BASE_URL=http://localhost:11434/v1
LOCAL_MODEL=llama3.1
